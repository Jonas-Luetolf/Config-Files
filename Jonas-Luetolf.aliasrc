alias la="ls -la"
alias ll="ls -ll"
alias c="clear"
alias rb="source ~/.bashrc"

alias sys-upgrade="sudo apt update && sudo apt upgrade -y"

# Python
actvenv() {
    if [ -d .venv ]; then
        source .venv/bin/activate
    elif [ -d venv ]; then
        source venv/bin/activate
    else
        echo "No virtual environment found (.venv or venv)"
    fi
}
